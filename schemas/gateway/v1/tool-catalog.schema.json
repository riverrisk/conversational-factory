{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.conversational-factory.local/gateway/v1/tool-catalog.schema.json",
  "title": "MCP Tool Catalog",
  "description": "Parent-repo proposal for advertising conversational-gateway capabilities to MCP clients and similar tool ecosystems.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "server_name",
    "version",
    "tools"
  ],
  "properties": {
    "server_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "input_schema"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "input_schema": {
            "type": "string",
            "description": "Schema id or path for the expected input payload."
          },
          "output_schema": {
            "type": "string",
            "description": "Schema id or path for the expected output payload."
          },
          "read_only": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
